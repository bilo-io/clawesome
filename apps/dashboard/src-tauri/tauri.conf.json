{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clawesome",
  "version": "0.1.0",
  "identifier": "com.clawesome.app",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Clawesome",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }

  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "src/clawesome-icon.svg"
    ],
    "externalBin": [
      "binaries/clawesome-cli",
      "binaries/clawesome-gateway"
    ]
  }
}
