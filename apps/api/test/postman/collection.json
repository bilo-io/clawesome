	"item": [
		{
			"name": "Agents",
			"item": [
				{
					"name": "Create Agent",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"pm.test(\"Agent has an ID\", function () {",
									"    pm.expect(jsonData.id).to.be.a('string');",
									"    pm.collectionVariables.set(\"agentId\", jsonData.id);",
									"});",
									"",
									"pm.test(\"Name matches\", function () {",
									"    pm.expect(jsonData.name).to.eql(\"Test Agent\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Agent\",\n    \"type\": \"general\",\n    \"content\": \"# Test Soul\\nThis is a test agent content.\",\n    \"config\": {\n        \"model\": \"gpt-4\"\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/{{apiVersion}}/agents",
